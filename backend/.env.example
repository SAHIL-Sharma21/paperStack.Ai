PORT=8001
NODE_ENV=development

#MONGO DB
MONGO_DB_URI=your_mongo_db_uri

#JWT
JWT_SECRET=your_jwt_secret
# JWT expiry in seconds (3600 = 1h, 86400 = 1d)
JWT_EXPIRATION_TIME=3600

# Auth cookie name (token stored in httpOnly cookie for web clients)
AUTH_COOKIE_NAME=access_token

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=paperstack-backend
KAFKA_TOPIC=document-processing

# File storage (local uploads; unused when using S3)
UPLOAD_DIR=./uploads

# Qdrant (apiKey optional for local; required for Qdrant Cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# Set to "true" to delete and recreate the documents collection (fixes VectorStruct schema mismatch)
# QDRANT_RECREATE_COLLECTION=true

# Embeddings: "gemini" (needs API key) or "fastembed" (local, no key)
EMBEDDING_PROVIDER=fastembed

# Gemini (required when EMBEDDING_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key