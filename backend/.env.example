PORT=8001
NODE_ENV=development

#MONGO DB
MONGO_INITDB_ROOT_USERNAME=paperstack_admin
MONGO_INITDB_ROOT_PASSWORD=change-me-mongo-password
MONGO_DB_URI=mongodb://${MONGO_INITDB_ROOT_USERNAME}:${MONGO_INITDB_ROOT_PASSWORD}@mongo:27017/paperstack?authSource=admin

#JWT (required before running docker compose)
JWT_SECRET=your_jwt_secret
# JWT expiry in seconds (3600 = 1h, 86400 = 1d)
JWT_EXPIRATION_TIME=3600

# Auth cookie name (token stored in httpOnly cookie for web clients)
AUTH_COOKIE_NAME=access_token

# Kafka 
KAFKA_BROKERS=localhost:19092
KAFKA_HOST_PORT=19092
KAFKA_CLIENT_ID=paperstack-backend
KAFKA_TOPIC=document-processing

# File storage (local uploads; unused when using S3)
UPLOAD_DIR=./uploads

# Qdrant (apiKey optional for local; required for Qdrant Cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# Set to "true" to delete and recreate the documents collection (fixes VectorStruct schema mismatch)
# QDRANT_RECREATE_COLLECTION=true
# Set to "true" if collection uses named vectors (fixes NamedVectorStruct search error on Qdrant Cloud)
# QDRANT_USE_NAMED_VECTOR=true

# Embeddings: "gemini" (needs API key) or "fastembed" (local, no key)
EMBEDDING_PROVIDER=fastembed

# Document chat LLM: "groq" (default) or "gemini"
LLM_PROVIDER=groq

# Groq (https://console.groq.com/docs/overview) — used when LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key
# Optional RAG / tool model (default: openai/gpt-oss-20b)
# GROQ_CHAT_MODEL=openai/gpt-oss-20b
# Optional Groq HTTP timeout in ms, including streaming body (default: 300000)
# GROQ_REQUEST_TIMEOUT_MS=300000

# Gemini — used when LLM_PROVIDER=gemini; also required when EMBEDDING_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
# Optional: Chat model for RAG (default: gemini-2.0-flash)
# GEMINI_CHAT_MODEL=gemini-2.0-flash
